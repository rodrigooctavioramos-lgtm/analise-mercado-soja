# Copie este arquivo para ".env" e preencha com seus dados reais.
# NUNCA suba o arquivo ".env" (com senha real) para um repositório Git.

# --- SMTP (envio do e-mail) ---
# Exemplo com Gmail + senha de app (myaccount.google.com/apppasswords):
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app-de-16-digitos

# Para quem tiver Outlook/Office 365 corporativo com autenticação básica
# ainda habilitada (cada vez mais raro):
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=seu-email@agrofoods.com.br
# SMTP_PASS=sua-senha

# --- Destinatário ---
RECIPIENT_EMAIL=rodrigo@seu-email.com
